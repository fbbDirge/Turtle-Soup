# OpenAI Compatible API (Gemini/DeepSeek/OpenAI)
VITE_GEMINI_API_KEY=your_api_key_here
VITE_GEMINI_API_URL=https://api.example.com/v1/chat/completions
VITE_GEMINI_MODEL=gemini-3-flash-preview

# Access Control (Optional)
VITE_ACCESS_PASSWORD=8888
VITE_AI_CONFIG_PASSWORD=8888
# Admin User ID (from Firebase Auth) for privileged actions (e.g. /skip, forced new game)
VITE_ADMIN_UID=ADMIN

# Firebase Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
